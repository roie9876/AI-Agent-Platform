{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "5873362563161388678"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "defaultValue": "agentlabs",
      "metadata": {
        "description": "Base name for all resources"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "swedencentral",
      "allowedValues": [
        "swedencentral",
        "eastus2",
        "westus3"
      ],
      "metadata": {
        "description": "Azure region for deployment"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "project": "AI-Agent-Platform-Labs",
        "environment": "development"
      },
      "metadata": {
        "description": "Tags to apply to all resources"
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[uniqueString(resourceGroup().id)]",
    "storageAccountName": "[format('{0}{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "searchServiceName": "[format('search-{0}-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "aiServicesName": "[format('ai-{0}-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "cosmosAccountName": "[format('cosmos-{0}-{1}', parameters('baseName'), variables('uniqueSuffix'))]",
    "contentSafetyName": "[format('safety-{0}-{1}', parameters('baseName'), variables('uniqueSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2023-10-01-preview",
      "name": "[variables('aiServicesName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "AIServices",
      "sku": {
        "name": "S0"
      },
      "properties": {
        "customSubDomainName": "[variables('aiServicesName')]",
        "publicNetworkAccess": "Enabled",
        "disableLocalAuth": false
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-10-01-preview",
      "name": "[format('{0}/{1}', variables('aiServicesName'), 'gpt-52')]",
      "sku": {
        "name": "Standard",
        "capacity": 30
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-5.2",
          "version": "2025-10-01"
        },
        "raiPolicyName": "Microsoft.DefaultV2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-10-01-preview",
      "name": "[format('{0}/{1}', variables('aiServicesName'), 'gpt-4o-mini')]",
      "sku": {
        "name": "Standard",
        "capacity": 60
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o-mini",
          "version": "2024-07-18"
        },
        "raiPolicyName": "Microsoft.DefaultV2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('aiServicesName'), 'gpt-52')]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2023-10-01-preview",
      "name": "[format('{0}/{1}', variables('aiServicesName'), 'text-embedding-3-large')]",
      "sku": {
        "name": "Standard",
        "capacity": 80
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "text-embedding-3-large",
          "version": "1"
        },
        "raiPolicyName": "Microsoft.DefaultV2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('aiServicesName'), 'gpt-4o-mini')]"
      ]
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2023-11-01",
      "name": "[variables('searchServiceName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "basic"
      },
      "properties": {
        "replicaCount": 1,
        "partitionCount": 1,
        "hostingMode": "default",
        "semanticSearch": "standard"
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2023-11-15",
      "name": "[variables('cosmosAccountName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0
          }
        ],
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "capabilities": [
          {
            "name": "EnableServerless"
          }
        ]
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases",
      "apiVersion": "2023-11-15",
      "name": "[format('{0}/{1}', variables('cosmosAccountName'), 'agent-platform')]",
      "properties": {
        "resource": {
          "id": "agent-platform"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2023-11-15",
      "name": "[format('{0}/{1}/{2}', variables('cosmosAccountName'), 'agent-platform', 'threads')]",
      "properties": {
        "resource": {
          "id": "threads",
          "partitionKey": {
            "paths": [
              "/thread_id"
            ],
            "kind": "Hash"
          },
          "defaultTtl": 604800
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosAccountName'), 'agent-platform')]"
      ]
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts/sqlDatabases/containers",
      "apiVersion": "2023-11-15",
      "name": "[format('{0}/{1}/{2}', variables('cosmosAccountName'), 'agent-platform', 'memory')]",
      "properties": {
        "resource": {
          "id": "memory",
          "partitionKey": {
            "paths": [
              "/user_id"
            ],
            "kind": "Hash"
          },
          "defaultTtl": 604800
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts/sqlDatabases', variables('cosmosAccountName'), 'agent-platform')]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2023-10-01-preview",
      "name": "[variables('contentSafetyName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "ContentSafety",
      "sku": {
        "name": "S0"
      },
      "properties": {
        "customSubDomainName": "[variables('contentSafetyName')]",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[take(variables('storageAccountName'), 24)]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/documents', take(variables('storageAccountName'), 24))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', take(variables('storageAccountName'), 24))]"
      ]
    }
  ],
  "outputs": {
    "aiServicesEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2023-10-01-preview').endpoint]"
    },
    "aiServicesKey": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2023-10-01-preview').key1]"
    },
    "searchServiceEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.search.windows.net', variables('searchServiceName'))]"
    },
    "searchServiceAdminKey": {
      "type": "string",
      "value": "[listAdminKeys(resourceId('Microsoft.Search/searchServices', variables('searchServiceName')), '2023-11-01').primaryKey]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName')), '2023-11-15').documentEndpoint]"
    },
    "cosmosKey": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosAccountName')), '2023-11-15').primaryMasterKey]"
    },
    "cosmosDatabaseName": {
      "type": "string",
      "value": "agent-platform"
    },
    "contentSafetyEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('contentSafetyName')), '2023-10-01-preview').endpoint]"
    },
    "contentSafetyKey": {
      "type": "string",
      "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('contentSafetyName')), '2023-10-01-preview').key1]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[take(variables('storageAccountName'), 24)]"
    },
    "storageConnectionString": {
      "type": "string",
      "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix=core.windows.net', take(variables('storageAccountName'), 24), listKeys(resourceId('Microsoft.Storage/storageAccounts', take(variables('storageAccountName'), 24)), '2023-01-01').keys[0].value)]"
    }
  }
}